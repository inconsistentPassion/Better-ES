<ui:FluentWindow x:Class="BetterES.View.BetterESWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  mc:Ignorable="d"
                  Title="BetterES"
                  MinWidth="580" MinHeight="600"
                  Width="700" Height="700"
                  ExtendsContentIntoTitleBar="True"
                  WindowStartupLocation="CenterScreen"
                  WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="TitleBar"
                     Title="BetterES"
                     Grid.Row="0">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="-16,0,0,0" VerticalAlignment="Center">
                    <!-- Icon placeholder -->
                    <Border Width="16" Height="16" Margin="0,0,6,0" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="2" />
                    <TextBlock Text="BetterES" VerticalAlignment="Center" FontSize="12" Opacity="0.9" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           MenuItemsSource="{Binding MenuItems}"
                           FooterMenuItemsSource="{Binding FooterMenuItems}"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           IsPaneOpen="{Binding IsNavigationPaneOpen, Mode=TwoWay}"
                           IsTopSeparatorVisible="False"
                           IsFooterSeparatorVisible="False"
                           OpenPaneLength="180"
                           CompactPaneLength="48"
                           SelectionChanged="OnNavigationSelectionChanged" />

        <ui:SnackbarPresenter x:Name="AppSnackbar"
                              Grid.Row="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,20" />

        <ui:ContentDialogHost x:Name="RootDialog" Grid.Row="1" />
    </Grid>
</ui:FluentWindow>
