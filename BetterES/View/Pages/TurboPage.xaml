<Page x:Class="BetterES.View.Pages.TurboPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <DataTemplate x:Key="BoostTickTemplate">
            <StackPanel>
                <Border Width="1" Height="12" Background="#20FFFFFF" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Label}"
                           FontSize="7"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Opacity="0.4"
                           HorizontalAlignment="Center"
                           Margin="0,1,0,0" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,12,20,0">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="Turbo" />
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12"
                           Text="AC turbo.ini physics — RPM-driven spool with throttle gating" />
                
                <ui:Card Margin="0,0,0,10" Padding="12,8">
                    <Grid>
                        <TextBlock Text="Functional Turbo" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <ui:ToggleSwitch x:Name="TurboFunctionalSwitch" HorizontalAlignment="Right" 
                                         OffContent="Simulation" OnContent="Functional"
                                         Checked="TurboFunctionalSwitch_Toggled" Unchecked="TurboFunctionalSwitch_Toggled"/>
                    </Grid>
                </ui:Card>

                <!-- Boost Gauge (tach-style) -->
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="4"
                        Padding="20,14"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Top: Status + Boost value -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Status pill -->
                            <Border Grid.Column="0"
                                    CornerRadius="4"
                                    Padding="6,6"
                                    MinWidth="48"
                                    VerticalAlignment="Center"
                                    BorderBrush="#254488FF"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#184488FF" Offset="0"/>
                                        <GradientStop Color="#084488FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TurboStatusText"
                                               Text="OFF"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#FF8080"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Start/Stop button -->
                            <ui:Button x:Name="TurboToggleButton" Content="Start" Appearance="Primary"
                                       FontSize="12" Click="TurboToggleButton_Click"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Bar + tick marks -->
                        <Grid Grid.Row="1" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="6" />
                                <RowDefinition Height="0" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Border Background="#08FFFFFF" CornerRadius="3" />

                                <Border x:Name="WastegateZone"
                                        CornerRadius="0" HorizontalAlignment="Right"
                                        Width="0" Opacity="0.12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FF4444" Offset="0"/>
                                            <GradientStop Color="#FFFF4444" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <Border x:Name="BoostBar"
                                        Width="0" CornerRadius="3" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop x:Name="BarColorStart" Color="#2266FF" Offset="0"/>
                                            <GradientStop x:Name="BarColorEnd" Color="#4488FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <Border x:Name="WastegateTick"
                                        Width="2" CornerRadius="1" HorizontalAlignment="Left"
                                        Margin="0,0,0,0" Background="#FF4444" Opacity="0.5" />
                            </Grid>

                            <ItemsControl Grid.Row="0" x:Name="BoostTickMarks" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>

                        <!-- Boost value large -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <TextBlock x:Name="BoostValueText" Text="0.0" FontSize="36" FontWeight="Bold" />
                            <TextBlock x:Name="BoostUnitText" Text="PSI" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Bottom" Margin="4,0,0,3" Opacity="0.5" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Expected Power Multiplier -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Expected Power at Full Boost" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBlock FontSize="11" Opacity="0.5" Margin="0,0,0,12" TextWrapping="Wrap"
                                   Text="AC formula: power × (1 + boost). Based on your turbo parameters." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock x:Name="PeakMultiplierText" Text="1.94×" FontSize="42" FontWeight="Bold"
                                           Foreground="#44FF88" HorizontalAlignment="Center" />
                                <TextBlock Text="at MAX_BOOST" FontSize="9" Opacity="0.5" HorizontalAlignment="Center" />
                                <TextBlock x:Name="PeakBoostLabel" Text="1.344 bar" FontSize="11" Opacity="0.4"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock x:Name="WgMultiplierText" Text="1.91×" FontSize="42" FontWeight="Bold"
                                           Foreground="#FFBB00" HorizontalAlignment="Center" />
                                <TextBlock Text="at WASTEGATE" FontSize="9" Opacity="0.5" HorizontalAlignment="Center" />
                                <TextBlock x:Name="WgBoostLabel" Text="1.300 bar" FontSize="11" Opacity="0.4"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <!-- Boost curve preview -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Curve" FontSize="11" Opacity="0.6" VerticalAlignment="Top" Margin="0,2,0,0" />
                            <Border Grid.Column="1" CornerRadius="4" Height="60" Background="#08FFFFFF"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                                    ClipToBounds="True" Padding="0">
                                <Canvas x:Name="CurveCanvas" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Turbo Parameters -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Turbo Parameters" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Max Boost" FontSize="12" />
                                <TextBlock Text="In Bars" FontSize="9" Opacity="0.4" />
                            </StackPanel>
                            <Slider x:Name="MaxBoostSlider" Grid.Column="1" Minimum="0.2" Maximum="4.0"
                                    Value="1.344" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="8,0"
                                    ValueChanged="ParamSlider_Changed" />
                            <TextBlock x:Name="MaxBoostText" Grid.Column="2" Text="1.344" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Wastegate" FontSize="12" />
                                <TextBlock Text="In Bars" FontSize="9" Opacity="0.4" />
                            </StackPanel>
                            <Slider x:Name="WastegateSlider" Grid.Column="1" Minimum="0.1" Maximum="4.0"
                                    Value="1.3" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="8,0"
                                    ValueChanged="ParamSlider_Changed" />
                            <TextBlock x:Name="WastegateText" Grid.Column="2" Text="1.300" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Peak Boost RPM" FontSize="12" />
                                <TextBlock Text="full boost RPM" FontSize="9" Opacity="0.4" />
                            </StackPanel>
                            <Slider x:Name="RefRpmSlider" Grid.Column="1" Minimum="1000" Maximum="8000"
                                    Value="3500" TickFrequency="100" IsSnapToTickEnabled="True" Margin="8,0"
                                    ValueChanged="ParamSlider_Changed" />
                            <TextBlock x:Name="RefRpmText" Grid.Column="2" Text="3500" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Curve" FontSize="12" />
                                <TextBlock Text="curve exponent" FontSize="9" Opacity="0.4" />
                            </StackPanel>
                            <Slider x:Name="GammaSlider" Grid.Column="1" Minimum="0.5" Maximum="4.0"
                                    Value="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="8,0"
                                    ValueChanged="ParamSlider_Changed" />
                            <TextBlock x:Name="GammaText" Grid.Column="2" Text="2.0" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Turbo Lag" FontSize="12" />
                                <TextBlock FontSize="9" Opacity="0.4" Text="Turbo Lag" />
                            </StackPanel>
                            <Slider x:Name="LagUpSlider" Grid.Column="1" Minimum="0.90" Maximum="1.0"
                                    Value="0.996" TickFrequency="0.001" IsSnapToTickEnabled="True" Margin="8,0"
                                    ValueChanged="ParamSlider_Changed" />
                            <TextBlock x:Name="LagUpText" Grid.Column="2" Text="0.996" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Vent Speed" FontSize="12" />
                                <TextBlock Text="Speed of BOV" FontSize="9" Opacity="0.4" />
                            </StackPanel>
                            <Slider x:Name="LagDnSlider" Grid.Column="1" Minimum="0.90" Maximum="1.0"
                                    Value="0.990" TickFrequency="0.001" IsSnapToTickEnabled="True" Margin="8,0"
                                    ValueChanged="ParamSlider_Changed" />
                            <TextBlock x:Name="LagDnText" Grid.Column="2" Text="0.990" FontSize="12"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Grid>

                        <!-- Efficiency removed as per user request -->
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
