<Page x:Class="BetterES.View.Pages.LogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Copy" Executed="CopyCommand_Executed" />
    </Page.CommandBindings>
    <Page.InputBindings>
        <KeyBinding Command="ApplicationCommands.Copy" Key="C" Modifiers="Ctrl" />
    </Page.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="20,12,20,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="Log" />
                    <TextBlock FontSize="12" Opacity="0.6" Text="All system and telemetry events" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="Copy All" Appearance="Secondary" FontSize="11"
                               Click="CopyButton_Click" Margin="0,0,8,0" />
                    <ui:Button Content="Clear" Appearance="Secondary" FontSize="11"
                               Click="ClearButton_Click" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Toolbar: search + filter -->
        <Grid Grid.Row="1" Margin="20,0,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Search box -->
            <TextBox x:Name="SearchBox" Grid.Column="0"
                     FontSize="11" FontFamily="Consolas, Courier New, monospace"
                     Padding="8,5" VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged"
                     KeyDown="SearchBox_KeyDown"
                     Tag="Search logs...">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Background" Value="#0CFFFFFF" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Filter combo -->
            <ComboBox x:Name="FilterCombo" Grid.Column="2" MinWidth="100" FontSize="11"
                      VerticalAlignment="Center" SelectionChanged="FilterCombo_SelectionChanged">
                <ComboBoxItem Content="All" Tag="All" IsSelected="True" />
                <ComboBoxItem Content="Info" Tag="Info" />
                <ComboBoxItem Content="Warnings" Tag="Warning" />
                <ComboBoxItem Content="Errors" Tag="Error" />
                <ComboBoxItem Content="Debug" Tag="Debug" />
            </ComboBox>
        </Grid>

        <!-- Log output — monospace, tail-style -->
        <Border Grid.Row="2" Margin="20,0,20,12"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="4" Background="#0A000000">
            <ScrollViewer x:Name="LogScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          ScrollChanged="LogScroller_ScrollChanged"
                          FontFamily="Consolas, Courier New, monospace"
                          FontSize="11"
                          Padding="8,6">
                <ItemsControl x:Name="LogList" ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Single-line log entry, colored by level -->
                            <TextBlock TextWrapping="NoWrap" LineHeight="18" Padding="0,1">
                                <!-- Timestamp -->
                                <Run Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss.fff}] '}"
                                     Foreground="#80FFFFFF" />
                                <!-- Level -->
                                <Run>
                                    <Run.Style>
                                        <Style TargetType="Run">
                                            <Setter Property="Text" Value="{Binding Level, StringFormat='[{0,-7}] '}" />
                                            <Setter Property="Foreground" Value="#4488FF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                    <Setter Property="Foreground" Value="#FFBB00" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Foreground" Value="#FF4444" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                    <Setter Property="Foreground" Value="#888888" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Run.Style>
                                </Run>
                                <!-- Source -->
                                <Run Text="{Binding Source, StringFormat='[{0}] '}"
                                     Foreground="#60FFFFFF" />
                                <!-- Message -->
                                <Run Text="{Binding Message}"
                                     Foreground="#D0FFFFFF" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
