<Page x:Class="BetterES.View.Pages.TimingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,12,20,0">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="Timing" />
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12" Text="Spark advance, rev limiter &amp; ignition control" />

                <!-- Enable Toggle -->
                <ui:Card Margin="0,0,0,8">
                    <Grid>
                        <TextBlock Text="Timing Control" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ui:ToggleSwitch x:Name="TimingEnabled" IsChecked="False" HorizontalAlignment="Right"
                                         Checked="TimingEnabled_Changed" Unchecked="TimingEnabled_Changed" />
                    </Grid>
                </ui:Card>

                <!-- Spark Advance -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Spark Advance" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock x:Name="AdvanceValue" Text="0°" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Right" Foreground="#44AAFF" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="-20°" FontSize="10" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Slider Grid.Column="1" x:Name="AdvanceSlider" Minimum="-20" Maximum="20" Value="0"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"
                                    ValueChanged="AdvanceSlider_ValueChanged" />
                            <TextBlock Grid.Column="2" Text="+20°" FontSize="10" Opacity="0.5" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>
                        <TextBlock FontSize="11" Opacity="0.5" Margin="0,4,0,0"
                                   Text="Negative = retard (safer), Positive = advance (more power)" />
                    </StackPanel>
                </ui:Card>

                <!-- Rev Limiter -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Rev Limiter" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ui:ToggleSwitch x:Name="RevLimiterEnabled" IsChecked="False" HorizontalAlignment="Right"
                                             Checked="RevLimiter_Changed" Unchecked="RevLimiter_Changed" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Limit RPM" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Slider Grid.Column="1" x:Name="RevLimitSlider" Minimum="2000" Maximum="12000" Value="7000"
                                    TickFrequency="100" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"
                                    ValueChanged="RevLimitSlider_ValueChanged" />
                            <TextBlock Grid.Column="2" x:Name="RevLimitValue" Text="7000"
                                       FontSize="14" FontWeight="Bold" Foreground="#FF6644"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cut Time (ms)" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Slider Grid.Column="1" x:Name="CutTimeSlider" Minimum="10" Maximum="200" Value="50"
                                    TickFrequency="5" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"
                                    ValueChanged="CutTimeSlider_ValueChanged" />
                            <TextBlock Grid.Column="2" x:Name="CutTimeValue" Text="50"
                                       FontSize="14" FontWeight="Bold" Foreground="#FF6644"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Ignition Cut (for shifts) -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Ignition Cut" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ui:ToggleSwitch x:Name="IgnitionCutEnabled" IsChecked="False" HorizontalAlignment="Right"
                                             Checked="IgnitionCut_Changed" Unchecked="IgnitionCut_Changed" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cut %" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Slider Grid.Column="1" x:Name="IgnitionCutSlider" Minimum="0" Maximum="100" Value="100"
                                    TickFrequency="5" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"
                                    ValueChanged="IgnitionCutSlider_ValueChanged" />
                            <TextBlock Grid.Column="2" x:Name="IgnitionCutValue" Text="100%"
                                       FontSize="14" FontWeight="Bold" Foreground="#FF4444"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>
                        <TextBlock FontSize="11" Opacity="0.5" Margin="0,4,0,0"
                                   Text="100% = hard cut (no combustion), partial = soft cut (retard)" />
                    </StackPanel>
                </ui:Card>

                <!-- Current Advance Display -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Live Telemetry" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="6" Background="#0AFFFFFF" Padding="12,8" Margin="0,0,4,0"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Advance" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="LiveAdvance" Text="--°" FontSize="24" FontWeight="Bold"
                                               Foreground="#44AAFF" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="6" Background="#0AFFFFFF" Padding="12,8" Margin="4,0,0,0"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="RPM" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="LiveRpm" Text="----" FontSize="24" FontWeight="Bold"
                                               Foreground="#FF8844" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
