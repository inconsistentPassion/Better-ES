<Page x:Class="BetterES.View.Pages.ExtraPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,12,20,0">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="Extra Features" />
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12" Text="Additional tools and plugins" />

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- MIDI Music Engine                                       -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <!-- Header -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🎵 MIDI Music Engine" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock FontSize="11" Opacity="0.5" Text="Load a MIDI file and make the engine play music (inspired by ES-Studio)" />
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="MidiStatusBadge" Background="#40FF4040" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                <TextBlock x:Name="MidiStatusText" Text="No File" FontSize="10" FontWeight="SemiBold" Foreground="#FF8080" />
                            </Border>
                        </Grid>

                        <!-- File Selection -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MidiFilePath" Grid.Column="0" IsReadOnly="True" FontSize="11"
                                     VerticalContentAlignment="Center" Text="No MIDI file loaded" />
                            <ui:Button x:Name="LoadMidiButton" Grid.Column="2" Content="📂 Load MIDI"
                                       Appearance="Secondary" FontSize="12" Click="LoadMidi_Click" />
                        </Grid>

                        <!-- MIDI Info -->
                        <Border Background="#08FFFFFF" CornerRadius="4" Padding="12,8" Margin="0,0,0,8" x:Name="MidiInfoPanel" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="TRACKS" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MidiTrackCount" Text="—" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="NOTES" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MidiNoteCount" Text="—" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="DURATION" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MidiDuration" Text="—" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="TEMPO" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MidiTempo" Text="—" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Playback Controls -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button x:Name="PlayButton" Grid.Column="0" Content="▶ Play"
                                       Appearance="Primary" FontSize="12" Click="PlayMidi_Click" IsEnabled="False" />
                            <ui:Button x:Name="PauseButton" Grid.Column="2" Content="⏸ Pause"
                                       Appearance="Secondary" FontSize="12" Click="PauseMidi_Click" IsEnabled="False" />
                            <ui:Button x:Name="StopButton" Grid.Column="4" Content="⏹ Stop"
                                       Appearance="Danger" FontSize="12" Click="StopMidi_Click" IsEnabled="False" />
                        </Grid>

                        <!-- Progress -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="MidiTimeElapsed" Grid.Column="0" Text="0:00" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                            <Slider x:Name="MidiProgressSlider" Grid.Column="2" Minimum="0" Maximum="100" Value="0"
                                    IsEnabled="False" VerticalAlignment="Center" />
                            <TextBlock x:Name="MidiTimeTotal" Grid.Column="4" Text="0:00" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                        </Grid>

                        <!-- Settings -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Low RPM" FontSize="12" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="MidiLowRpm" Text="1000" FontSize="12" Width="80"
                                         VerticalContentAlignment="Center" TextChanged="MidiLowRpm_TextChanged" />
                                <TextBlock Text="RPM" FontSize="11" Opacity="0.5" VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="High RPM" FontSize="12" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="MidiHighRpm" Text="8000" FontSize="12" Width="80"
                                         VerticalContentAlignment="Center" />
                                <TextBlock Text="RPM" FontSize="11" Opacity="0.5" VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tempo Multiplier" FontSize="12" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="MidiTempoSlider" Minimum="0.25" Maximum="2.0" Value="1.0"
                                        Width="160" IsSnapToTickEnabled="True" TickFrequency="0.05"
                                        VerticalAlignment="Center" />
                                <TextBlock x:Name="MidiTempoLabel" Text="1.00x" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Note Length Mode" FontSize="12" VerticalAlignment="Center" />
                            <ComboBox x:Name="MidiNoteLengthMode" Grid.Column="1" MinWidth="160" FontSize="12">
                                <ComboBoxItem Content="Full Duration" Tag="Full" IsSelected="True" />
                                <ComboBoxItem Content="Staccato (short blips)" Tag="Staccato" />
                                <ComboBoxItem Content="Legato (slight overlap)" Tag="Legato" />
                            </ComboBox>
                        </Grid>

                        <!-- Current Note Display -->
                        <Border Background="#08FFFFFF" CornerRadius="4" Padding="12,10" Margin="0,0,0,8" x:Name="MidiNowPlaying" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="NOTE" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MidiCurrentNote" Text="—" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="TARGET RPM" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MidiCurrentRpm" Text="—" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#60A5FA" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="OCTAVE" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="MidiCurrentOctave" Text="—" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Note Piano Roll -->
                        <Border Background="#08FFFFFF" CornerRadius="4" Padding="12,8" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Note Roll" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,6" />
                                <Border x:Name="PianoRollContainer" Height="60" Background="#10FFFFFF" CornerRadius="4" ClipToBounds="True">
                                    <Canvas x:Name="PianoRollCanvas" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
