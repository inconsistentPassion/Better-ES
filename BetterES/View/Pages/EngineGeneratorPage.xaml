<Page x:Class="BetterES.View.Pages.EngineGeneratorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,12,20,0">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="Engine Generator" />
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12" Text="Generate Engine Simulator compatible engine definitions" />

                <!-- Status + Live Stats -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="StatusBadge" Background="#4040FF80" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="Ready" FontSize="10" FontWeight="SemiBold" Foreground="#80FF80" />
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border CornerRadius="4" Background="#0AFFFFFF" Padding="10,4" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Displacement:" FontSize="11" Opacity="0.5" Margin="0,0,6,0" />
                                <TextBlock x:Name="LiveDisplacement" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="#44AAFF" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="4" Background="#0AFFFFFF" Padding="10,4" Margin="8,0,0,0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Bore×Stroke:" FontSize="11" Opacity="0.5" Margin="0,0,6,0" />
                                <TextBlock x:Name="LiveBoreStroke" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="#44AAFF" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="4" Background="#0AFFFFFF" Padding="10,4" Margin="8,0,0,0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Layout:" FontSize="11" Opacity="0.5" Margin="0,0,6,0" />
                                <TextBlock x:Name="LiveLayout" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="#44AAFF" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Engine Basics -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="⚙️ Engine Basics" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Engine Name" FontSize="12" VerticalAlignment="Center" />
                            <TextBox x:Name="EngineName" Grid.Column="1" Text="My Engine" FontSize="12" VerticalContentAlignment="Center" />
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Layout" FontSize="12" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="LayoutInline" Content="Inline" Margin="0,0,16,0" GroupName="EngineLayout" IsChecked="True" Checked="Layout_Checked" />
                                <RadioButton x:Name="LayoutV" Content="V" Margin="0,0,16,0" GroupName="EngineLayout" Checked="Layout_Checked" />
                                <RadioButton x:Name="LayoutFlat" Content="Flat" GroupName="EngineLayout" Checked="Layout_Checked" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bore" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="BoreSlider" Grid.Column="1" Minimum="50" Maximum="130" Value="86" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="BoreLabel" Text="86" />
                                <Run Text=" mm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Stroke" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="StrokeSlider" Grid.Column="1" Minimum="40" Maximum="120" Value="86" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="StrokeLabel" Text="86" />
                                <Run Text=" mm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cylinders" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="CylinderSlider" Grid.Column="1" Minimum="1" Maximum="16" Value="4" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="CylinderLabel" Text="4" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Redline RPM" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="RedlineSlider" Grid.Column="1" Minimum="3000" Maximum="12000" Value="7500" IsSnapToTickEnabled="True" TickFrequency="100" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="RedlineLabel" Text="7500" />
                                <Run Text=" RPM" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Compression" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="CompressionSlider" Grid.Column="1" Minimum="6" Maximum="16" Value="10.5" IsSnapToTickEnabled="True" TickFrequency="0.1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="CompressionLabel" Text="10.5" />
                                <Run Text=":1" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Geometry & Mass -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="📐 Geometry &amp; Mass" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Rod Length" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="RodLengthSlider" Grid.Column="1" Minimum="80" Maximum="250" Value="140" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="RodLengthLabel" Text="140" />
                                <Run Text=" mm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Rod Mass" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="RodMassSlider" Grid.Column="1" Minimum="100" Maximum="2000" Value="600" IsSnapToTickEnabled="True" TickFrequency="10" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="RodMassLabel" Text="600" />
                                <Run Text=" g" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Comp. Height" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="CompHeightSlider" Grid.Column="1" Minimum="20" Maximum="60" Value="32" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="CompHeightLabel" Text="32" />
                                <Run Text=" mm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Chamber Vol." FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="ChamberVolSlider" Grid.Column="1" Minimum="10" Maximum="100" Value="45" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="ChamberVolLabel" Text="45" />
                                <Run Text=" cc" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Flywheel Mass" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="FlywheelMassSlider" Grid.Column="1" Minimum="1" Maximum="30" Value="8" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="FlywheelMassLabel" Text="8" />
                                <Run Text=" kg" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Flywheel Radius" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="FlywheelRadiusSlider" Grid.Column="1" Minimum="5" Maximum="40" Value="15" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="FlywheelRadiusLabel" Text="15" />
                                <Run Text=" cm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Camshaft -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="🔧 Camshaft &amp; Valvetrain" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="LSA" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="LsaSlider" Grid.Column="1" Minimum="95" Maximum="120" Value="110" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="LsaLabel" Text="110" />
                                <Run Text="°" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Intake Duration" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="IntakeDurationSlider" Grid.Column="1" Minimum="180" Maximum="320" Value="240" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="IntakeDurationLabel" Text="240" />
                                <Run Text="°" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Exhaust Duration" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="ExhaustDurationSlider" Grid.Column="1" Minimum="180" Maximum="320" Value="240" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="ExhaustDurationLabel" Text="240" />
                                <Run Text="°" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Intake Lift" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="IntakeLiftSlider" Grid.Column="1" Minimum="5" Maximum="18" Value="10" IsSnapToTickEnabled="True" TickFrequency="0.1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="IntakeLiftLabel" Text="10.0" />
                                <Run Text=" mm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Exhaust Lift" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="ExhaustLiftSlider" Grid.Column="1" Minimum="5" Maximum="18" Value="10" IsSnapToTickEnabled="True" TickFrequency="0.1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="ExhaustLiftLabel" Text="10.0" />
                                <Run Text=" mm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Intake / Exhaust -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="💨 Intake &amp; Exhaust" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Intake Runner Len." FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="IntakeRunnerLenSlider" Grid.Column="1" Minimum="5" Maximum="80" Value="25" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="IntakeRunnerLenLabel" Text="25" />
                                <Run Text=" cm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Intake Runner Vol." FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="IntakeRunnerVolSlider" Grid.Column="1" Minimum="50" Maximum="1000" Value="200" IsSnapToTickEnabled="True" TickFrequency="10" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="IntakeRunnerVolLabel" Text="200" />
                                <Run Text=" cc" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Plenum Volume" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="PlenumVolSlider" Grid.Column="1" Minimum="0" Maximum="20" Value="3" IsSnapToTickEnabled="True" TickFrequency="0.1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="PlenumVolLabel" Text="3.0" />
                                <Run Text=" L" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Exhaust Prim. Len." FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="ExhaustPrimLenSlider" Grid.Column="1" Minimum="10" Maximum="100" Value="40" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="ExhaustPrimLenLabel" Text="40" />
                                <Run Text=" cm" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Exhaust Runner Vol." FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="ExhaustRunnerVolSlider" Grid.Column="1" Minimum="50" Maximum="1000" Value="300" IsSnapToTickEnabled="True" TickFrequency="10" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="ExhaustRunnerVolLabel" Text="300" />
                                <Run Text=" cc" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>
                        
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Idle Throttle" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="IdleThrottleSlider" Grid.Column="1" Minimum="0.990" Maximum="1.000" Value="0.997" IsSnapToTickEnabled="True" TickFrequency="0.0001" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="IdleThrottleLabel" Text="0.997" />
                                <Run Text="" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Ignition & Firing Order -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="⚡ Ignition &amp; Firing Order" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Spark Advance" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="SparkAdvanceSlider" Grid.Column="1" Minimum="0" Maximum="45" Value="15" IsSnapToTickEnabled="True" TickFrequency="0.5" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="SparkAdvanceLabel" Text="15" />
                                <Run Text="°" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Firing Order" FontSize="12" VerticalAlignment="Center" />
                            <TextBox x:Name="FiringOrderBox" Grid.Column="1" Text="1,3,4,2" FontSize="12" VerticalContentAlignment="Center" />
                        </Grid>

                        <Grid x:Name="BankAngleRow" Margin="0,0,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bank Angle" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="BankAngleSlider" Grid.Column="1" Minimum="0" Maximum="180" Value="90" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="BankAngleLabel" Text="90" />
                                <Run Text="°" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </ui:Card>


                <!-- Vehicle -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="🚗 Vehicle" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mass" FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="VehicleMassSlider" Grid.Column="1" Minimum="500" Maximum="5000" Value="1500" IsSnapToTickEnabled="True" TickFrequency="50" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="VehicleMassLabel" Text="1500" />
                                <Run Text=" kg" Foreground="#80FFFFFF" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Drag Coeff." FontSize="12" VerticalAlignment="Center" />
                            <Slider x:Name="DragCoeffSlider" Grid.Column="1" Minimum="0.1" Maximum="0.6" Value="0.25" IsSnapToTickEnabled="True" TickFrequency="0.01" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center">
                                <Run x:Name="DragCoeffLabel" Text="0.25" />
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
