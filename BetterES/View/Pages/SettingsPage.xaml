<Page x:Class="BetterES.View.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,12,20,0">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="Settings" />
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12" Text="Configure BetterES" />

                <!-- Appearance -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <!-- Theme -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Theme" FontSize="12" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="DarkRadio" Content="Dark" FontSize="12"
                                             Margin="0,0,16,0" Checked="ThemeRadio_Changed"
                                             GroupName="Theme" />
                                <RadioButton x:Name="LightRadio" Content="Light" FontSize="12"
                                             Checked="ThemeRadio_Changed"
                                             GroupName="Theme" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Units -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Units" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="System" FontSize="12" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="MetricRadio" Content="Metric" FontSize="12"
                                             Margin="0,0,16,0" Checked="UnitRadio_Changed"
                                             GroupName="Units" />
                                <RadioButton x:Name="ImperialRadio" Content="Imperial" FontSize="12"
                                             Checked="UnitRadio_Changed"
                                             GroupName="Units" />
                            </StackPanel>
                        </Grid>

                        <!-- Preview -->
                        <Border Background="#08FFFFFF" CornerRadius="4" Padding="12,8" Margin="0,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="SPEED" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="SpeedPreview" Text="100 km/h" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="BOOST" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="BoostPreview" Text="1.00 bar" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="TEMP" FontSize="9" Opacity="0.4" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="TempPreview" Text="90°C" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ui:Card>

                <!-- Window -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Window" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <CheckBox x:Name="StayOnTopCheckBox"
                                  Content="Stay on top"
                                  FontSize="12"
                                  Checked="StayOnTop_Changed"
                                  Unchecked="StayOnTop_Changed" />
                    </StackPanel>
                </ui:Card>

                <!-- About -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="About" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock FontSize="11" Opacity="0.6" ><Run Text="BetterES — All In One Tool"/></TextBlock>
                        <TextBlock FontSize="11" Opacity="0.4" ><Run Text="0.1.0 alpha"/></TextBlock>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
