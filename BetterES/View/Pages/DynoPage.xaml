<Page x:Class="BetterES.View.Pages.DynoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,12,20,0">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="Dyno" />
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12" Text="Real-time horsepower and torque" />

                <!-- Live Readouts -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0" Margin="0,0,4,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="HORSEPOWER"
                                       FontSize="8" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock x:Name="HpText" Text="0"
                                       FontSize="40" FontWeight="Bold" Foreground="#4488FF"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="hp" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Column="1" Margin="4,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="TORQUE"
                                       FontSize="8" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock x:Name="TorqueText" Text="0"
                                       FontSize="40" FontWeight="Bold" Foreground="#FF8800"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="lb-ft" FontSize="10" Opacity="0.5" HorizontalAlignment="Center" />
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <!-- RPM -->
                <ui:Card Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Current RPM" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" x:Name="RpmText" Text="0" FontSize="16" FontWeight="Bold" />
                    </Grid>
                </ui:Card>

                <!-- Dyno Graph -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Dyno Graph" FontSize="14" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <!-- Baseline legend -->
                                <Ellipse Width="8" Height="8" Fill="#66777777" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="Baseline" FontSize="10" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <!-- Current legend -->
                                <Ellipse Width="8" Height="8" Fill="#4488FF" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="HP" FontSize="10" Foreground="#4488FF" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <Ellipse Width="8" Height="8" Fill="#FF8800" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="Torque" FontSize="10" Foreground="#FF8800" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <Canvas x:Name="GraphCanvas" Height="280"
                                ClipToBounds="True"
                                Background="{DynamicResource ControlFillColorDefaultBrush}" />
                    </StackPanel>
                </ui:Card>

                <!-- Graph Controls -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:Button x:Name="SaveBaselineBtn" Content="Save as Baseline" Appearance="Secondary" FontSize="12"
                               Click="SaveBaseline_Click" Margin="0,0,8,0" />
                    <ui:Button x:Name="ClearBaselineBtn" Content="Clear Baseline" Appearance="Secondary" FontSize="12"
                               Click="ClearBaseline_Click" Margin="0,0,8,0" />
                    <ui:Button Content="Reset" Appearance="Secondary" FontSize="12"
                               Click="ResetPeaks_Click" />
                </StackPanel>

                <!-- Peak Values -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Peak Power" FontSize="12" />
                            <TextBlock x:Name="PeakHpText" Text="0 hp @ 0 RPM" FontSize="12" FontWeight="SemiBold"
                                       HorizontalAlignment="Right" Foreground="#4488FF" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="Peak Torque" FontSize="12" />
                            <TextBlock x:Name="PeakTorqueText" Text="0 lb-ft @ 0 RPM" FontSize="12" FontWeight="SemiBold"
                                       HorizontalAlignment="Right" Foreground="#FF8800" />
                        </Grid>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
