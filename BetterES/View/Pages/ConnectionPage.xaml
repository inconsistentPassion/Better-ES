<Page x:Class="BetterES.View.Pages.ConnectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:BetterES.View.Controls"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,12,20,0">
        <StackPanel>
            <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="Connection" />
            <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12" Text="Game telemetry from Assetto Corsa &amp; BeamNG.drive" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:Card Grid.Column="0">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Game Telemetry" FontSize="14" FontWeight="SemiBold" />
                            <Border x:Name="GameStatusBadge" Grid.Column="1" Background="#40FF4040" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock x:Name="GameStatusText" Text="Offline" FontSize="10" FontWeight="SemiBold" Foreground="#FF8080" />
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton x:Name="AssettoCorsaRadio" Content="AC" Margin="0,0,12,0" GroupName="GameSelector" Checked="GameSelector_Checked" />
                            <RadioButton x:Name="BeamNGRadio" Content="BeamNG" Margin="0,0,12,0" GroupName="GameSelector" Checked="GameSelector_Checked" />
                            <StackPanel x:Name="BeamNGPortRow" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="Port:" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.5" />
                                <TextBox x:Name="BeamNGPortBox" Text="4444" FontSize="10" Width="50" Padding="2" />
                            </StackPanel>
                        </StackPanel>
                        <ui:Button x:Name="ConnectGameButton" Content="Connect Game" Appearance="Primary" FontSize="12" HorizontalAlignment="Stretch" Click="ConnectGameButton_Click" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Grid.Column="2">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Engine Simulator" FontSize="14" FontWeight="SemiBold" />
                            <Border x:Name="EsStatusBadge" Grid.Column="1" Background="#40FF4040" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock x:Name="EsStatusText" Text="Offline" FontSize="10" FontWeight="SemiBold" Foreground="#FF8080" />
                            </Border>
                        </Grid>
                        <TextBlock FontSize="11" Opacity="0.5" Margin="0,0,0,12" TextWrapping="Wrap" Text="Enable high-speed bi-directional MMF bridge for real-time physics control." />
                        <ui:Button x:Name="ConnectEsButton" Content="Connect ES" Appearance="Secondary" FontSize="12" HorizontalAlignment="Stretch" Click="ConnectEsButton_Click" />
                    </StackPanel>
                </ui:Card>
            </Grid>
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Text="Tachometer" FontSize="14" FontWeight="SemiBold" Grid.Column="0" />
                        <TextBlock x:Name="GameSourceLabel" Text="—" FontSize="11" Opacity="0.4" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                    <controls:Tachometer x:Name="TachometerControl" CurrentRpm="0" MaxRpm="8000" CurrentGear="0" />
                </StackPanel>
            </ui:Card>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:Card Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="Speed" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <controls:SpeedGauge x:Name="SpeedGaugeControl" CurrentSpeed="0" MaxSpeed="300" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Grid.Column="2">
                    <StackPanel>
                        <TextBlock Text="Turbo" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <controls:BoostGauge x:Name="TurboGaugeControl" CurrentBoost="0" MaxBoost="3.0" Wastegate="2.5" />
                    </StackPanel>
                </ui:Card>
            </Grid>
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Connection Log" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                        <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Height="180">
                            <TextBlock x:Name="LogTextBlock" FontSize="10" FontFamily="Consolas,Courier New" TextWrapping="Wrap" Text="Log messages will appear here..." />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
