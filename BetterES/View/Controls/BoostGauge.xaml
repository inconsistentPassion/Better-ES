<UserControl x:Class="BetterES.View.Controls.BoostGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="96">

    <UserControl.Resources>
        <DataTemplate x:Key="TickMarkTemplate">
            <StackPanel>
                <Border Width="1" Height="12" Background="#20FFFFFF" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Label}"
                           FontSize="7"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Opacity="0.4"
                           HorizontalAlignment="Center"
                           Margin="0,1,0,0" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
            CornerRadius="4"
            Padding="20,14"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top: Label + Boost value -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Boost pill -->
                <Border Grid.Column="0"
                        CornerRadius="4"
                        Padding="6,6"
                        MinWidth="48"
                        VerticalAlignment="Center"
                        x:Name="PillBorder"
                        BorderBrush="#2544FF88"
                        BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop x:Name="PillColorTop" Color="#1844FF88" Offset="0"/>
                            <GradientStop x:Name="PillColorBot" Color="#0844FF88" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="BOOST"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#44FF88"
                               x:Name="PillText"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- Boost value right-aligned -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="BoostBarText"
                               Text="0.00"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <StackPanel VerticalAlignment="Bottom" Margin="4,0,0,0">
                        <TextBlock Text="bar"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Opacity="0.5" />
                        <TextBlock x:Name="BoostPsiText"
                                   Text="0.0 psi"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Opacity="0.4" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Bar + tick marks -->
            <Grid Grid.Row="1" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="6" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <!-- Track -->
                    <Border Background="#08FFFFFF" CornerRadius="3" />

                    <!-- Wastegate marker -->
                    <Border x:Name="WastegateTick"
                            Width="2"
                            CornerRadius="1"
                            HorizontalAlignment="Left"
                            Background="#FF8844"
                            Opacity="0.5" />

                    <!-- Fill -->
                    <Border x:Name="ProgressBar"
                            Width="0"
                            CornerRadius="3"
                            HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop x:Name="BarColorStart" Color="#22CC44" Offset="0"/>
                                <GradientStop x:Name="BarColorEnd" Color="#44FF66" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <ItemsControl Grid.Row="0" x:Name="TickMarks" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>
